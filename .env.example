# Environment Variables — CoreCount Local C.O.R.E. Engine
# Copy this file to .env and fill in your values

# --- Server ---
PORT=5000

# --- Admin Security ---
# 4-digit PIN for volunteer dispense actions. Server-side only.
ADMIN_PIN=1234

# --- Database ---
# Path to the local SQLite database file (relative to project root)
DATABASE_PATH=data/pdh_core.db

# --- AI Model Provider ---
# Placeholder — swap this with your Qualcomm model endpoint when ready
# AI_PROVIDER=qualcomm
# AI_MODEL_INTAKE=<your-intake-model-name>
# AI_MODEL_CONSENSUS_A=<your-consensus-model-A>
# AI_MODEL_CONSENSUS_B=<your-consensus-model-B>
# AI_ENDPOINT=http://localhost:<your-local-model-port>

# --- Ollama (legacy / currently placeholder) ---
# OLLAMA_URL=http://localhost:11434

# --- Email Notifications (optional) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=yourpassword
# SMTP_FROM=corecount@projectdignityhobbs.org
