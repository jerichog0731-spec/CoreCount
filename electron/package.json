{
  "name": "corecount-desktop",
  "version": "1.0.0",
  "description": "CoreCount C.O.R.E. Engine — Desktop App Launcher",
  "main": "main.cjs",
  "private": true,
  "scripts": {
    "start":   "electron .",
    "build":   "electron-builder build --win nsis",
    "release": "electron-builder build --win nsis --publish always"
  },
  "dependencies": {
    "electron-log":     "^5.2.4",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron":         "^31.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId":       "org.projectdignityhobbs.corecount",
    "productName": "CoreCount",
    "copyright":   "Project Dignity Hobbs",
    "publish": {
      "provider": "github",
      "owner":    "jerichog0731-spec",
      "repo":     "CoreCount",
      "releaseType": "release"
    },
    "directories": {
      "output": "C:\\Users\\Jeric\\Desktop\\CoreCount-Release"
    },
    "files": [
      "main.cjs",
      "preload.cjs"
    ],
    "extraResources": [],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "artifactName":              "CoreCount-Setup.exe",
      "requestedExecutionLevel":   "asInvoker"
    },
    "nsis": {
      "oneClick":              true,
      "perMachine":            false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName":          "CoreCount",
      "deleteAppDataOnUninstall": false
    }
  }
}
