{
  "name": "corecount-desktop",
  "version": "1.0.0",
  "description": "CoreCount C.O.R.E. Engine — Desktop App Launcher",
  "main": "main.cjs",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win nsis"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "org.projectdignityhobbs.corecount",
    "productName": "CoreCount",
    "copyright": "Project Dignity Hobbs",
    "directories": {
      "output": "C:\\Users\\Jeric\\Desktop\\CoreCount-Release"
    },
    "files": [
      "main.cjs",
      "preload.cjs"
    ],
    "extraResources": [],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "artifactName": "CoreCount-Setup.exe",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CoreCount"
    }
  }
}
